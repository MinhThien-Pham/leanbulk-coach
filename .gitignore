# .gitignore — LeanBulk Coach

# =============================================================================
# Secrets — NEVER commit
# =============================================================================
.env
*.key
*.pem
*.p12
*.pfx

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
nosetests.xml
coverage/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Database
# =============================================================================
*.db
*.sqlite
*.sqlite3
leanbulk.db

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Node / Frontend (Phase 3)
# =============================================================================
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.local

# =============================================================================
# Docker
# =============================================================================
.dockerignore

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
