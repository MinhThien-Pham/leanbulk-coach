# ===========================================================================
# LeanBulk Coach — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Google AI / Gemini
# ---------------------------------------------------------------------------
# Your Google AI Studio or Vertex AI API key.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_api_key_here

# The Gemini model to use for the agent.
# For development:  gemini-2.0-flash-001  (fast, low-cost)
# For eval/demo:    gemini-2.5-pro-001    (best quality, if available)
# See README for how to check available models.
GEMINI_MODEL=gemini-2.0-flash-001

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# Shared API key for authenticating requests to the FastAPI backend.
# For local single-user demo: any strong random string is fine.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_backend_api_key_here

# Backend server port (default: 8000)
PORT=8000

# Allowed CORS origins (comma-separated). For local frontend dev:
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite database path (relative to backend/ directory).
# Default creates leanbulk.db in the project root.
DATABASE_URL=sqlite+aiosqlite:///./leanbulk.db

# ---------------------------------------------------------------------------
# MCP Server
# ---------------------------------------------------------------------------
# Path to the MCP server script (relative to project root).
MCP_SERVER_PATH=backend/mcp/server.py

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
