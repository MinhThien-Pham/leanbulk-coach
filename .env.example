# ===========================================================================
# LeanBulk Coach — Local Environment
# ===========================================================================

# Backend server port.
PORT=8000

# SQLite database URL for local manual runs.
# Docker Compose sets the same value automatically for the backend container.
LEANBULK_DATABASE_URL=sqlite+aiosqlite:///./leanbulk_api.db

# Frontend API base URL for Vite.
VITE_API_BASE_URL=http://localhost:8000
